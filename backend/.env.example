NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:8081
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oco_local
SESSION_SECRET=replace-with-a-local-secret-at-least-16-characters
COOKIE_DOMAIN=localhost
MEDIA_BASE_URL=http://localhost:4000/uploads
GA4_MEASUREMENT_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
# Required: do not keep defaults in real environments
DEFAULT_ADMIN_EMAIL=admin@your-domain.com
DEFAULT_ADMIN_PASSWORD=change-this-to-a-strong-password
PRIVATE_PAGE_DEFAULT_USERNAME=partner-access-user
PRIVATE_PAGE_DEFAULT_PASSWORD=change-this-to-a-strong-password
CMS_QUERY_TIMEOUT_MS=600
CMS_CIRCUIT_BREAKER_MS=30000
CMS_RENDERING_ENABLED=true
